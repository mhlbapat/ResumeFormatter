{
  "manifest_version": 3,
  "name": "ResumeFormatter",
  "version": "0.1.0",
  "description": "Generate a tailored resume from pasted job text using your local ResumeFormatter backend.",
  "permissions": [
    "downloads"
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "ResumeFormatter",
    "default_popup": "popup.html"
  }
}

